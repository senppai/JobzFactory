@model JF.DAL.Context.Offre
@{
    ViewBag.Title = "Edit offer";
    ViewBag.Section = "Offers";
}

<div class="jf-ad-header">
    <div>
        <h1>Edit offer</h1>
        <p>Update listing #@Model.id — @Model.titreOffre</p>
    </div>
    <a href="~/Offre/Index" class="jf-ad-btn jf-ad-btn--ghost"><i class="fa-solid fa-arrow-left"></i> Back to list</a>
</div>

<div class="jf-ad-card">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(model => model.id)
        @Html.ValidationSummary(true, "", new { @class = "jf-ad-alert jf-ad-alert--danger" })

        <div class="jf-ad-form">
            <div class="jf-ad-form-section">
                <h3>Job details</h3>
                <div class="jf-ad-form-grid">
                    <div class="jf-ad-form-grid--full">
                        <div class="form-group">
                            <label for="titreOffre">Title</label>
                            @Html.EditorFor(model => model.titreOffre, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.titreOffre, "", new { @class = "jf-ad-validation" })
                        </div>
                    </div>
                    <div class="jf-ad-form-grid--full">
                        <div class="form-group">
                            <label for="message">Description</label>
                            @Html.TextAreaFor(model => model.message, new { @class = "form-control", rows = 6 })
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="url">URL slug</label>
                        @Html.EditorFor(model => model.url, new { htmlAttributes = new { @class = "form-control" } })
                    </div>
                    <div class="form-group">
                        <label for="adresseMailAPostuler">Application email</label>
                        @Html.EditorFor(model => model.adresseMailAPostuler, new { htmlAttributes = new { @class = "form-control", type = "email" } })
                    </div>
                    <div class="form-group">
                        <label for="nomImage">Image name</label>
                        @Html.EditorFor(model => model.nomImage, new { htmlAttributes = new { @class = "form-control" } })
                    </div>
                    <div class="form-group">
                        <label for="numberOffre">Offer number</label>
                        @Html.EditorFor(model => model.numberOffre, new { htmlAttributes = new { @class = "form-control" } })
                    </div>
                </div>
            </div>

            <div class="jf-ad-form-section">
                <h3>Classification</h3>
                <div class="jf-ad-form-grid">
                    <div class="form-group">
                        <label for="C_idRecruteur">Recruiter</label>
                        @Html.DropDownList("C_idRecruteur", null, "Select recruiter…", new { @class = "form-control jf-ad-select", data_placeholder = "Select recruiter…" })
                    </div>
                    <div class="form-group">
                        <label for="C_idVille">City</label>
                        @Html.DropDownList("C_idVille", null, "Select city…", new { @class = "form-control jf-ad-select", data_placeholder = "Select city…" })
                    </div>
                    <div class="form-group">
                        <label for="C_idSecteurActivite">Sector</label>
                        @Html.DropDownList("C_idSecteurActivite", null, "Select sector…", new { @class = "form-control jf-ad-select", data_placeholder = "Select sector…" })
                    </div>
                </div>
            </div>

            <div class="jf-ad-form-section">
                <h3>Settings</h3>
                <div class="jf-ad-form-grid">
                    <div class="form-group">
                        <label class="jf-ad-check">
                            @Html.EditorFor(model => model.isPublie)
                            <span>Published</span>
                        </label>
                    </div>
                    <div class="form-group">
                        <label class="jf-ad-check">
                            @Html.EditorFor(model => model.isConfidentiel)
                            <span>Confidential listing</span>
                        </label>
                    </div>
                </div>
            </div>

            <div class="jf-ad-form-actions">
                <button type="submit" class="jf-ad-btn jf-ad-btn--primary"><i class="fa-solid fa-check"></i> Save changes</button>
                <a href="~/Offre/Details/@Model.id" class="jf-ad-btn jf-ad-btn--ghost">View details</a>
                <a href="~/Offre/Index" class="jf-ad-btn jf-ad-btn--ghost">Cancel</a>
            </div>
        </div>
    }
</div>
