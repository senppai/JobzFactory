@model JF.DAL.Context.Recruteur
@{
    ViewBag.Title = "Recruiter details";
    ViewBag.Section = "Recruiters";
}

<div class="jf-ad-header">
    <div>
        <h1>@Model.nomRecruteur</h1>
        <p>Recruiter #@Model.id</p>
    </div>
    <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
        <a href="@Url.Action("Edit", new { id = Model.id })" class="jf-ad-btn jf-ad-btn--primary"><i class="fa-solid fa-pen"></i> Edit</a>
        <a href="~/Recruteur/Index" class="jf-ad-btn jf-ad-btn--ghost"><i class="fa-solid fa-arrow-left"></i> Back</a>
    </div>
</div>

<div class="jf-ad-card">
    <dl class="jf-ad-details">
        <div class="jf-ad-detail">
            <dt>Company name</dt>
            <dd>@Model.nomRecruteur</dd>
        </div>
        <div class="jf-ad-detail">
            <dt>Email</dt>
            <dd>@(string.IsNullOrWhiteSpace(Model.adresseMail) ? "—" : Model.adresseMail)</dd>
        </div>
        <div class="jf-ad-detail">
            <dt>Website</dt>
            <dd>@(string.IsNullOrWhiteSpace(Model.siteweb) ? "—" : Model.siteweb)</dd>
        </div>
        <div class="jf-ad-detail">
            <dt>URL slug</dt>
            <dd>@(string.IsNullOrWhiteSpace(Model.url) ? "—" : Model.url)</dd>
        </div>
        <div class="jf-ad-detail">
            <dt>Created</dt>
            <dd>@Model.dateCreation.ToString("g")</dd>
        </div>
        <div class="jf-ad-detail">
            <dt>Social address</dt>
            <dd>@(string.IsNullOrWhiteSpace(Model.adresseSocial) ? "—" : Model.adresseSocial)</dd>
        </div>
    </dl>

    @if (!string.IsNullOrWhiteSpace(Model.description))
    {
        <div style="margin-top:1.25rem;padding-top:1.25rem;border-top:1px solid #f1f5f9;">
            <h3 style="margin:0 0 0.75rem;font-size:0.95rem;font-weight:700;">Description</h3>
            <p style="margin:0;color:#475569;line-height:1.7;white-space:pre-wrap;">@Model.description</p>
        </div>
    }
</div>
