@model JF.DAL.Context.Recruteur
@{
    ViewBag.Title = "Create recruiter";
    ViewBag.Section = "Recruiters";
}

<div class="jf-ad-header">
    <div>
        <h1>Create recruiter</h1>
        <p>Add a new employer company profile.</p>
    </div>
    <a href="~/Recruteur/Index" class="jf-ad-btn jf-ad-btn--ghost"><i class="fa-solid fa-arrow-left"></i> Back to list</a>
</div>

<div class="jf-ad-card">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "jf-ad-alert jf-ad-alert--danger" })

        <div class="jf-ad-form">
            <div class="jf-ad-form-grid">
                <div class="form-group">
                    <label for="nomRecruteur">Company name</label>
                    @Html.EditorFor(model => model.nomRecruteur, new { htmlAttributes = new { @class = "form-control", placeholder = "Company name" } })
                    @Html.ValidationMessageFor(model => model.nomRecruteur, "", new { @class = "jf-ad-validation" })
                </div>
                <div class="form-group">
                    <label for="adresseMail">Email</label>
                    @Html.EditorFor(model => model.adresseMail, new { htmlAttributes = new { @class = "form-control", type = "email" } })
                </div>
                <div class="form-group">
                    <label for="siteweb">Website</label>
                    @Html.EditorFor(model => model.siteweb, new { htmlAttributes = new { @class = "form-control", placeholder = "https://…" } })
                </div>
                <div class="form-group">
                    <label for="url">URL slug</label>
                    @Html.EditorFor(model => model.url, new { htmlAttributes = new { @class = "form-control" } })
                </div>
                <div class="form-group">
                    <label for="dateCreation">Created date</label>
                    @Html.EditorFor(model => model.dateCreation, new { htmlAttributes = new { @class = "form-control" } })
                </div>
                <div class="form-group">
                    <label for="adresseSocial">Social address</label>
                    @Html.EditorFor(model => model.adresseSocial, new { htmlAttributes = new { @class = "form-control" } })
                </div>
                <div class="jf-ad-form-grid--full">
                    <div class="form-group">
                        <label for="description">Description</label>
                        @Html.TextAreaFor(model => model.description, new { @class = "form-control", rows = 5, placeholder = "Company description…" })
                    </div>
                </div>
            </div>

            <div class="jf-ad-form-actions">
                <button type="submit" class="jf-ad-btn jf-ad-btn--primary"><i class="fa-solid fa-check"></i> Create recruiter</button>
                <a href="~/Recruteur/Index" class="jf-ad-btn jf-ad-btn--ghost">Cancel</a>
            </div>
        </div>
    }
</div>
