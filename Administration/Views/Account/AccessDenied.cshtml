@{
    Layout = null;
    ViewBag.Title = "Access denied";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Access denied · JobzFactory Administration</title>
    <link href="@Url.Content("~/Content/admin-modern.css")" rel="stylesheet" />
    <style>
        body { margin: 0; background: #0f172a; font-family: 'Plus Jakarta Sans', system-ui, sans-serif; }
        .jf-adm-denied { min-height: 100vh; display: grid; place-items: center; padding: 1.5rem; text-align: center; }
        .jf-adm-denied__card { background:#fff; border-radius:16px; padding:2.5rem; max-width:480px; }
        .jf-adm-denied__card h1 { color:#dc2626; margin:0 0 .5rem; }
        .jf-adm-denied__card p { color:#64748b; }
        .jf-adm-denied__btn { display:inline-block; margin-top:1rem; padding:.7rem 1.2rem; background:#4f46e5; color:#fff; border-radius:8px; text-decoration:none; font-weight:700; }
    </style>
</head>
<body>
    <div class="jf-adm-denied">
        <div class="jf-adm-denied__card">
            <h1>Access denied</h1>
            <p>You do not have permission to view this page.</p>
            <a href="@Url.Action("Login", "Account")" class="jf-adm-denied__btn">Go to sign in</a>
        </div>
    </div>
</body>
</html>
