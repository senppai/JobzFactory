@{
    Layout = null;
    ViewBag.Title = "Admin sign in";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>JobzFactory · Administration</title>
    <link href="@Url.Content("~/Content/admin-modern.css")" rel="stylesheet" />
    <style>
        body { margin: 0; background: #0f172a; font-family: 'Plus Jakarta Sans', system-ui, sans-serif; }
        .jf-adm-login { min-height: 100vh; display: grid; place-items: center; padding: 1.5rem; }
        .jf-adm-login__card { width: 100%; max-width: 420px; background: #fff; border-radius: 16px; padding: 2rem; box-shadow: 0 20px 50px rgba(0,0,0,.35); }
        .jf-adm-login__card h1 { margin: 0 0 .25rem; font-size: 1.5rem; color: #0f172a; }
        .jf-adm-login__card p { margin: 0 0 1.5rem; color: #64748b; font-size: .95rem; }
        .jf-adm-login__field { margin-bottom: 1rem; }
        .jf-adm-login__field label { display: block; font-size: .85rem; color: #334155; margin-bottom: .35rem; font-weight: 600; }
        .jf-adm-login__field input { width: 100%; box-sizing: border-box; padding: .7rem .8rem; border: 1px solid #cbd5e1; border-radius: 8px; font-size: .95rem; }
        .jf-adm-login__field input:focus { outline: none; border-color: #4f46e5; box-shadow: 0 0 0 3px rgba(79,70,229,.15); }
        .jf-adm-login__btn { width: 100%; padding: .8rem; background: #4f46e5; color: #fff; border: none; border-radius: 8px; font-weight: 700; cursor: pointer; font-size: 1rem; }
        .jf-adm-login__btn:hover { background: #4338ca; }
        .jf-adm-login__error { color: #dc2626; font-size: .85rem; margin-bottom: 1rem; }
    </style>
</head>
<body>
    <div class="jf-adm-login">
        <div class="jf-adm-login__card">
            <h1>Administration</h1>
            <p>Sign in to manage offers and recruiters.</p>

            @using (Html.BeginForm("Login", "Account", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "jf-adm-login__error" })
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                <div class="jf-adm-login__field">
                    <label>Username</label>
                    <input type="text" name="username" autocomplete="username" required autofocus />
                </div>

                <div class="jf-adm-login__field">
                    <label>Password</label>
                    <input type="password" name="password" autocomplete="current-password" required />
                </div>

                <button type="submit" class="jf-adm-login__btn">Sign in</button>
            }
        </div>
    </div>
</body>
</html>
