<?xml version="1.0" encoding="utf-8"?>

<!-- Release transform for the Recruteur (employer) portal.
     Replace the placeholders below with real production values on deploy. -->

<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">

  <!-- Production SQL Server connection (SQL auth). Replace PROD-SQL / credentials on deploy. -->
  <connectionStrings>
    <add name="jobzFactoryEntities"
         connectionString="metadata=res://*/Context.Model.csdl|res://*/Context.Model.ssdl|res://*/Context.Model.msl;provider=System.Data.SqlClient;provider connection string=&quot;Data Source=PROD-SQL;Initial Catalog=jobzFactory;User ID=jobzfactory_app;Password=CHANGE_ME;MultipleActiveResultSets=True;App=EntityFramework&quot;"
         providerName="System.Data.EntityClient"
         xdt:Transform="SetAttributes" xdt:Locator="Match(name)" />
  </connectionStrings>

  <appSettings>
    <!-- Production public portal URL. -->
    <add key="UrlMain" value="https://www.jobzfactory.com/"
         xdt:Transform="SetAttributes" xdt:Locator="Match(key)" />
    <!-- Override the CV token secret with a strong, unique production value. -->
    <add key="CvTokenSecret" value="CHANGE_ME_PRODUCTION_CV_TOKEN_SECRET"
         xdt:Transform="SetAttributes" xdt:Locator="Match(key)" />
  </appSettings>

  <system.web>
    <compilation xdt:Transform="RemoveAttributes(debug)" />
    <httpCookies requireSSL="true" xdt:Transform="SetAttributes" />
    <authentication>
      <forms requireSSL="true" xdt:Transform="SetAttributes" />
    </authentication>
  </system.web>

</configuration>
