@using PagedList
@using PagedList.Mvc
@model PagedList.IPagedList<JF.DAL.Context.Offre>
@{
    var currentPage = Model.PageCount < Model.PageNumber ? 0 : Model.PageNumber;
    var search = ViewBag.Search as string ?? string.Empty;
    var status = ViewBag.Status as string ?? "all";
    var sector = ViewBag.Sector as int?;
    var city = ViewBag.City as int?;
    var hasFilters = !string.IsNullOrWhiteSpace(search) || status != "all" || sector.HasValue || city.HasValue;
}

<div id="offer-list-results"
     class="jf-rc-offer-results"
     data-page="@currentPage"
     data-page-count="@Model.PageCount"
     data-total="@Model.TotalItemCount"
     data-on-page="@Model.Count">

    @if (Model.Any())
    {
        <div class="jf-rc-table-wrap">
            <table class="jf-rc-table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Sector</th>
                        <th>City</th>
                        <th>Applications</th>
                        <th>Status</th>
                        <th>Published</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <a href="@Url.Action("Board", new { id = item.id })">@item.titreOffre</a>
                            </td>
                            <td>@(item.SecteurActivite != null ? item.SecteurActivite.SecteurActivite1 : "—")</td>
                            <td>@(item.Ville != null ? item.Ville.ville1 : "—")</td>
                            <td>@item.Offre_Postuler.Count</td>
                            <td>
                                @if (item.isPublie)
                                {
                                    <span class="jf-rc-badge jf-rc-badge--live">Live</span>
                                }
                                else
                                {
                                    <span class="jf-rc-badge jf-rc-badge--draft">Draft</span>
                                }
                            </td>
                            <td>
                                @if (item.isPublie)
                                {
                                    using (Html.BeginForm("disable", "Annonce", FormMethod.Post, new { style = "display:inline;" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        @Html.Hidden("id", item.id)
                                        <button type="submit" title="Unpublish"
                                                data-confirm-title="Unpublish this offer?"
                                                data-confirm-message="The job will be hidden from the public site."
                                                data-confirm-btn="Unpublish"
                                                data-confirm-variant="warning"
                                                style="background:none;border:none;cursor:pointer;padding:0;">
                                            <i class="fa-solid fa-toggle-on" style="color:#15803d;font-size:1.5rem;"></i>
                                        </button>
                                    }
                                }
                                else
                                {
                                    using (Html.BeginForm("Approve", "Annonce", FormMethod.Post, new { style = "display:inline;" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        @Html.Hidden("id", item.id)
                                        <button type="submit" title="Publish"
                                                data-confirm-title="Publish this offer?"
                                                data-confirm-message="The job will become visible on the public job site."
                                                data-confirm-btn="Publish"
                                                data-confirm-variant="primary"
                                                style="background:none;border:none;cursor:pointer;padding:0;">
                                            <i class="fa-solid fa-toggle-off" style="color:#dc2626;font-size:1.5rem;"></i>
                                        </button>
                                    }
                                }
                            </td>
                            <td>
                                <div class="jf-rc-row-actions">
                                    <a href="@Url.Action("Board", new { id = item.id })" class="jf-rc-row-actions__board" title="Board"><i class="fa-solid fa-table-columns"></i> Board</a>
                                    <a href="@Url.Action("Edit", new { id = item.id })" class="jf-rc-row-actions__edit" title="Edit"><i class="fa-solid fa-pen-to-square"></i> Edit</a>
                                    <a href="@Url.Action("Delete", new { id = item.id })"
                                       class="jf-rc-row-actions__danger" title="Delete"
                                       data-confirm-title="Delete this offer?"
                                       data-confirm-message="You will be taken to the delete page to permanently remove this offer and its applications."
                                       data-confirm-btn="Delete"
                                       data-confirm-variant="danger"><i class="fa-solid fa-trash"></i> Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="jf-rc-empty">
            <h2>No offers found</h2>
            <p>Try adjusting your search or filters, or create a new listing.</p>
            @if (!hasFilters)
            {
                <a href="~/Annonce/Create" class="jf-rc-btn jf-rc-btn--primary">Create offer</a>
            }
        </div>
    }

    @if (Model.PageCount > 1)
    {
        <nav class="jf-rc-pagination" aria-label="Offers pagination">
            <p class="jf-rc-pagination__info">
                Showing @Model.Count of @Model.TotalItemCount offers — Page @currentPage of @Model.PageCount
            </p>
            @Html.PagedListPager(
                Model,
                page => Url.Action("Index", new { Page = page, search = search, status = status, sector = sector, city = city }),
                new PagedListRenderOptions { LiElementClasses = new[] { "jf-rc-page-item" } })
        </nav>
    }
    else if (Model.TotalItemCount > 0)
    {
        <p class="jf-rc-pagination__info" style="padding:1rem 1.15rem;margin:0;">
            Showing @Model.TotalItemCount offer@(Model.TotalItemCount == 1 ? "" : "s")
        </p>
    }
</div>
