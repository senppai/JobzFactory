@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewBag.Title = "Registration complete";
}

<div class="jf-rc-status">
    <div class="jf-rc-status__card">
        <div style="font-size:3rem;margin-bottom:1rem;">✓</div>
        <h1>Thanks for signing up!</h1>
        <p>Your employer account is ready. You can now sign in with your work email and password.</p>
        <a href="~/Login" class="jf-rc-btn jf-rc-btn--primary">Sign in</a>
    </div>
</div>
