@model Recruteur.Models.LoginViewModel
@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewBag.Title = "Employer Sign In";
}

<div class="jf-rc-auth">
    <div class="jf-rc-auth__brand">
        <div class="jf-rc-auth__brand-inner">
            <h2>Employer portal</h2>
            <p>Manage job offers, review applicants, and publish listings on Jobz Factory.</p>
        </div>
    </div>

    <div class="jf-rc-auth__form-side">
        <div class="jf-rc-auth__form-wrap jf-rc-form">
            <h1>Sign in</h1>
            <p>Enter your employer account credentials.</p>

            @using (Html.BeginForm("index", "Login", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "jf-rc-auth__error" })

                <div class="form-group">
                    <label>Username or email</label>
                    @Html.EditorFor(model => model.compte, new { htmlAttributes = new { @class = "form-control", placeholder = "Your username or email" } })
                </div>

                <div class="form-group">
                    <label>Password</label>
                    @Html.PasswordFor(model => model.motPasse, new { @class = "form-control", placeholder = "Your password" })
                </div>

                <button class="jf-rc-btn jf-rc-btn--primary" type="submit" style="width:100%;margin-top:0.5rem;">Sign in</button>

                <p style="margin-top:1.25rem;color:#64748b;font-size:0.9rem;">
                    Don't have an account? <a href="~/Login/SignUp" style="color:#4f46e5;font-weight:600;">Sign up</a>
                </p>
            }
        </div>
    </div>
</div>
