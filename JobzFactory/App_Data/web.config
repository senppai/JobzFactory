<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.web>
    <httpHandlers>
      <add path="*" verb="*" type="System.Web.HttpNotFoundHandler" />
    </httpHandlers>
  </system.web>
  <system.webServer>
    <handlers>
      <add name="BlockAppData" path="*" verb="*" type="System.Web.HttpNotFoundHandler" preCondition="integratedMode" />
    </handlers>
  </system.webServer>
</configuration>
