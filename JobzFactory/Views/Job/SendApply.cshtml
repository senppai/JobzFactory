@{
    ViewBag.Title = "Application sent";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link href="~/css/job-modern.css" rel="stylesheet" />

<div class="jf-job-page">
    <section class="jf-success">
        <div class="jf-success__card">
            <div class="jf-success__icon" aria-hidden="true">
                <span class="icon-check"></span>
            </div>
            <h1 class="jf-success__title">Application sent!</h1>
            <p class="jf-success__text">
                Thank you for applying. Your CV and details have been submitted successfully.
                The employer will review your application and contact you if your profile matches their needs.
            </p>
            <div class="jf-success__actions">
                <a href="~/#jobs" class="jf-btn jf-btn--primary">
                    <span class="icon-briefcase"></span> Browse more jobs
                </a>
                <a href="~/" class="jf-btn jf-btn--ghost">Back to home</a>
            </div>
        </div>
    </section>
</div>
