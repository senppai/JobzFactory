@model JobzFactory.Models.ResetViewModel
@{
    Layout = null;
    ViewBag.Title = "Reset password";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Jobz Factory — Reset password</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="@Url.Content("~/css/signup-modern.css")" rel="stylesheet" />
</head>
<body>
    <section class="jf-status">
        <div class="jf-status__card">
            @if (ViewBag.Invalid != null && (bool)ViewBag.Invalid)
            {
                <div class="jf-status__icon" aria-hidden="true" style="background:linear-gradient(135deg,#dc2626,#ef4444);">!</div>
                <h1 class="jf-status__title">Link invalid</h1>
                <p class="jf-status__text">This password reset link is invalid or has expired.</p>
                <div class="jf-status__actions" style="margin-top:1.5rem;">
                    <a href="@Url.Action("Forgot","Account")" class="jf-btn jf-btn--primary">Request a new link</a>
                    <a href="@Url.Action("Login","Account")" class="jf-btn jf-btn--ghost">Back to sign in</a>
                </div>
            }
            else
            {
                <div class="jf-status__icon" aria-hidden="true">&#10003;</div>
                <h1 class="jf-status__title">Choose a new password</h1>
                <p class="jf-status__text">Enter your new password below to regain access to your account.</p>

                @using (Html.BeginForm("Reset", "Account", FormMethod.Post, new { @style = "text-align:left;margin:1.5rem 0;" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.token)
                    @Html.ValidationSummary(true, "", new { @class = "jf-auth__error" })

                    <div class="form-group" style="margin-bottom:1.25rem;">
                        <label for="motPasse" style="display:block;font-size:0.85rem;font-weight:600;color:#475569;margin-bottom:0.4rem;">New password</label>
                        @Html.EditorFor(model => model.motPasse, new { htmlAttributes = new { @class = "form-control", @id = "motPasse", @placeholder = "At least 8 characters", @required = "required", @style = "width:100%;padding:0.8rem 1rem;border:1px solid #e2e8f0;border-radius:12px;font-size:0.95rem;" } })
                        @Html.ValidationMessageFor(model => model.motPasse, "", new { @class = "jf-auth__error" })
                    </div>

                    <div class="form-group" style="margin-bottom:1.25rem;">
                        <label for="confirmMotPasse" style="display:block;font-size:0.85rem;font-weight:600;color:#475569;margin-bottom:0.4rem;">Confirm password</label>
                        @Html.EditorFor(model => model.confirmMotPasse, new { htmlAttributes = new { @class = "form-control", @id = "confirmMotPasse", @placeholder = "Re-enter your new password", @required = "required", @style = "width:100%;padding:0.8rem 1rem;border:1px solid #e2e8f0;border-radius:12px;font-size:0.95rem;" } })
                        @Html.ValidationMessageFor(model => model.confirmMotPasse, "", new { @class = "jf-auth__error" })
                    </div>

                    <button class="jf-btn jf-btn--primary" type="submit">Reset password</button>
                }
            }
        </div>
    </section>
</body>
</html>
