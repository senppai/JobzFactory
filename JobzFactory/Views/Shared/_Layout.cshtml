<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jobz Factory - @ViewBag.Title </title>

    <link href="https://fonts.googleapis.com/css?family=Nunito+Sans:200,300,400,600,700,800,900" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/open-iconic-bootstrap.min.css">
    <link rel="stylesheet" href="~/css/animate.css">

    <link rel="stylesheet" href="~/css/owl.carousel.min.css">
    <link rel="stylesheet" href="~/css/owl.theme.default.min.css">
    <link rel="stylesheet" href="~/css/magnific-popup.css">

    <link rel="stylesheet" href="~/css/aos.css">

    <link rel="stylesheet" href="~/css/ionicons.min.css">

    <link rel="stylesheet" href="~/css/bootstrap-datepicker.css">
    <link rel="stylesheet" href="~/css/jquery.timepicker.css">

    <link href="~/Content/PagedList.css" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/flaticon.css">
    <link rel="stylesheet" href="~/css/icomoon.css">
    <link rel="stylesheet" href="~/css/style.css">
    <link rel="stylesheet" href="~/css/nav-modern.css?v=20260702b">
    <link rel="stylesheet" href="~/css/footer-modern.css?v=20260702b">
    <link rel="stylesheet" href="~/css/profile-modern.css?v=20260702b">
    <!-- Global site tag (gtag.js) - Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=UA-178020454-1"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());

        gtag('config', 'UA-178020454-1');
    </script>

    @RenderSection("styles", required: false)

</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark ftco_navbar bg-dark ftco-navbar-light" id="ftco-navbar">
        <div class="container">
            <a class="navbar-brand" href="~/">Job Z Factory</a>
            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#ftco-nav" aria-controls="ftco-nav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="oi oi-menu"></span> Menu
            </button>

            <div class="collapse navbar-collapse" id="ftco-nav">
                <ul class="navbar-nav ml-auto">
                    <li class="nav-item jf-nav-item">
                        <a href="@System.Configuration.ConfigurationManager.AppSettings["UrlRecruteur"]" class="jf-nav-btn jf-nav-btn--employer" target="_blank" rel="noopener noreferrer">
                            <span class="icon-briefcase"></span>
                            <span>Employer Sign In</span>
                        </a>
                    </li>
                    @if (User.Identity.IsAuthenticated && User.IsInRole("Candidate"))
                    {
                        <li class="nav-item jf-nav-item">
                            <a href="@Url.Action("Index","Profile")" class="jf-nav-btn jf-nav-btn--profile">
                                <span class="icon-user"></span>
                                <span>My Profile</span>
                            </a>
                        </li>
                        <li class="nav-item jf-nav-item">
                            <a href="@Url.Action("LogOut","Account")" class="jf-nav-btn jf-nav-btn--ghost">Logout</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item jf-nav-item">
                            <a href="@Url.Action("Login","Account")" class="jf-nav-btn jf-nav-btn--ghost">Sign in</a>
                        </li>
                        <li class="nav-item jf-nav-item">
                            <a href="@Url.Action("Register","SignUp")" class="jf-nav-btn jf-nav-btn--profile">
                                <span class="icon-user"></span>
                                <span>Create Profile</span>
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
    <!-- END nav -->
    @RenderBody()


    <footer class="jf-footer">
        <div class="container">
            <div class="jf-footer__grid">
                <div>
                    <a href="~/" class="jf-footer__brand-name">
                        <span>JF</span> Jobz Factory
                    </a>
                    <p class="jf-footer__tagline">
                        Connecting talented professionals with leading employers across Morocco. Find your next opportunity or hire the right candidate today.
                    </p>
                    <ul class="jf-footer__social">
                        <li><a href="#" aria-label="LinkedIn"><span class="icon-linkedin"></span></a></li>
                        <li><a href="#" aria-label="Facebook"><span class="icon-facebook"></span></a></li>
                        <li><a href="#" aria-label="Twitter"><span class="icon-twitter"></span></a></li>
                        <li><a href="#" aria-label="Instagram"><span class="icon-instagram"></span></a></li>
                    </ul>
                </div>

                <div>
                    <h3 class="jf-footer__heading">For Job Seekers</h3>
                    <ul class="jf-footer__links">
                        <li><a href="~/#jobs">Browse Jobs</a></li>
                        <li><a href="@Url.Action("Register", "SignUp")">Create Profile</a></li>
                        <li><a href="~/#jobs">Apply to a Job</a></li>
                    </ul>
                </div>

                <div>
                    <h3 class="jf-footer__heading">For Employers</h3>
                    <ul class="jf-footer__links">
                        <li><a href="@System.Configuration.ConfigurationManager.AppSettings["UrlRecruteur"]" target="_blank" rel="noopener noreferrer">Post a Job</a></li>
                        <li><a href="@System.Configuration.ConfigurationManager.AppSettings["UrlRecruteur"]" target="_blank" rel="noopener noreferrer">Employer Login</a></li>
                        <li><a href="@System.Configuration.ConfigurationManager.AppSettings["UrlRecruteur"]" target="_blank" rel="noopener noreferrer">Find Candidates</a></li>
                    </ul>
                </div>

                <div>
                    <h3 class="jf-footer__heading">Contact Us</h3>
                    <ul class="jf-footer__contact">
                        <li>
                            <span class="jf-footer__contact-icon"><span class="icon-map-marker"></span></span>
                            <span>Casablanca - Morocco</span>
                        </li>
                        <li>
                            <span class="jf-footer__contact-icon"><span class="icon-phone"></span></span>
                            <a href="tel:+212522847391">+212 522 847 391</a>
                        </li>
                        <li>
                            <span class="jf-footer__contact-icon"><span class="icon-envelope"></span></span>
                            <a href="mailto:hello@jobzfactory.ma">hello@jobzfactory.ma</a>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="jf-footer__bottom">
                <p>&copy; <script>document.write(new Date().getFullYear());</script> Jobz Factory. All rights reserved.</p>
                <div class="jf-footer__legal">
                    <a href="#">Privacy Policy</a>
                    <a href="#">Terms of Service</a>
                    <a href="#">Cookies</a>
                </div>
            </div>
        </div>
    </footer>



    <!-- loader -->
    <div id="ftco-loader" class="show fullscreen">
        <svg class="circular" width="48px" height="48px">
            <circle class="path-bg" cx="24" cy="24" r="22" fill="none" stroke-width="4" stroke="#eeeeee" />
            <circle class="path" cx="24" cy="24" r="22" fill="none" stroke-width="4" stroke-miterlimit="10" stroke="#F96D00" />
        </svg>
    </div>


    <script src="~/js/jquery.min.js"></script>
    <script src="~/js/jquery-migrate-3.0.1.min.js"></script>
    <script src="~/js/popper.min.js"></script>
    <script src="~/js/bootstrap.min.js"></script>
    <script src="~/js/jquery.easing.1.3.js"></script>
    <script src="~/js/jquery.waypoints.min.js"></script>
    <script src="~/js/jquery.stellar.min.js"></script>
    <script src="~/js/owl.carousel.min.js"></script>
    <script src="~/js/jquery.magnific-popup.min.js"></script>
    <script src="~/js/aos.js"></script>
    <script src="~/js/jquery.animateNumber.min.js"></script>
    <script src="~/js/bootstrap-datepicker.js"></script>
    <script src="~/js/jquery.timepicker.min.js"></script>
    <script src="~/js/scrollax.min.js"></script>
    <script src="https://maps.googleapis.com/maps/api/js?key=@System.Configuration.ConfigurationManager.AppSettings["GoogleMapsApiKey"]&sensor=false"></script>
    <script src="~/js/google-map.js"></script>
    <script src="~/js/main.js"></script>
    @RenderSection("scripts", required: false)

</body>
</html>